# Copy this file to .env.

# 공유 SQLite DB 경로. 기본값은 editable install된 data-pipeline 소스 트리 안의
# crawling/db/reports.db (db.py가 자동으로 찾음). 다른 경로를 쓰려면 지정.
# DATABASE_PATH=../ant-secretariat-data-pipeline/crawling/db/reports.db

# agents/trend_report (Agent D) — Upstage/Pinecone 필수 키
UPSTAGE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=

# 선택 사항 (기본값 solar-mini)
# TREND_REPORT_LLM_MODEL=solar-mini
# TREND_REPORT_AS_OF_DATE=2026-06-28
# TREND_REPORT_REPORT_TOP_K=8
# TREND_REPORT_NEWS_TOP_K=5
# TREND_REPORT_MACRO_TOP_K=3

# agents/simulation (Agent G) — 리스크 분류 LLM 모델
# (기본값 solar-mini — 5개 변수 중 고르는 좁은 분류 작업이라 경량 모델로 충분)
# RISK_CLASSIFIER_MODEL=solar-mini

# agents/insight_board (Agent E) — 숫자 데이터 1~2줄 코멘트 생성 모델
# (기본값 solar-mini — 짧은 요약이라 경량 모델로 충분)
# INSIGHT_BOARD_LLM_MODEL=solar-mini

# agents/debate (Agent F) — Bull/Bear/Judge 논쟁 생성 모델
# (기본값 solar-mini. 더 강한 모델을 쓸 때는 Upstage 콘솔의 현재 model id로 override)
# DEBATE_LLM_MODEL=solar-mini
